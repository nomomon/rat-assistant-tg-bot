# Telegram (use TELEGRAM_BOT_TOKEN or TELEGRAM_BOT_KEY)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Optional: set in setWebhook and sent as X-Telegram-Bot-Api-Secret-Token
# WEBHOOK_SECRET_TOKEN=your_random_secret

# Allowed users (comma-separated Telegram user IDs)
ALLOWED_TELEGRAM_USER_IDS=123456789,987654321

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=sk-...

# Gemini (use GOOGLE_API_KEY or GEMINI_API_KEY)
GOOGLE_API_KEY=...
